# =============================================================================
# KayanoClient — 美术与大资源（建议走网盘 / FileServer / Git LFS，不进 GitHub）
# =============================================================================

# 全量美术：角色、特效、Timeline 动作资产等（AssetArt 约数千文件）
KayanoClient/Assets/AssetArt/
KayanoClient/Assets/AssetArt.meta

# AssetRaw 中体积大或 Luban 可再生成的部分
KayanoClient/Assets/AssetRaw/
KayanoClient/Assets/AssetRaw/Configs/bytes/*.bytes.meta

# 若 Audio / 场景 / 模型 也放在 AssetRaw 子目录，可取消注释：
# KayanoClient/Assets/AssetRaw/Audio/
# KayanoClient/Assets/AssetRaw/Scenes/
# KayanoClient/Assets/AssetRaw/Models/

# 字体源文件（SDF 与 ttf 在 AssetRaw/Fonts 已整目录忽略；勿全局忽略 *.ttf，否则 TextMesh Pro 会缺字库）

# 二进制资源扩展名（限 Assets 下，避免误伤仓库根目录文档）
KayanoClient/Assets/**/*.psd
KayanoClient/Assets/**/*.tga
KayanoClient/Assets/**/*.tif
KayanoClient/Assets/**/*.tiff
KayanoClient/Assets/**/*.exr
KayanoClient/Assets/**/*.hdr
KayanoClient/Assets/**/*.fbx
KayanoClient/Assets/**/*.FBX
KayanoClient/Assets/**/*.obj
KayanoClient/Assets/**/*.blend
KayanoClient/Assets/**/*.max
KayanoClient/Assets/**/*.ma
KayanoClient/Assets/**/*.mb
KayanoClient/Assets/**/*.wav
KayanoClient/Assets/**/*.mp3
KayanoClient/Assets/**/*.ogg
KayanoClient/Assets/**/*.aif
KayanoClient/Assets/**/*.aiff
KayanoClient/Assets/**/*.mp4
KayanoClient/Assets/**/*.mov
KayanoClient/Assets/**/*.avi

